# Grafana (http://localhost:3000)
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=changeme

# Watchtower — registry kontrol aralığı (saniye, varsayılan 300)
WATCHTOWER_POLL_INTERVAL=10

# Private Docker Hub image ise watchtower servisine ekle:
# WATCHTOWER_REPO_USER=
# WATCHTOWER_REPO_PASS=
